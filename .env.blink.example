/**
 * Environment Variables Configuration for Blink API
 * 
 * Copy this to your .env file and fill in your Blink API credentials
 * 
 * Get API credentials from: https://dev.blink.sv/
 */

# ============================================
# BLINK API CONFIGURATION
# ============================================

# Blink API Endpoint
# Default: https://api.blink.sv/graphql (production)
# For testing: https://api.blink.sv/graphql (Apollo sandbox also available)
BLINK_API_URL=https://api.blink.sv/graphql

# Blink API Key
# Generate from Blink console: https://dashboard.blink.sv/
# Keep this secret! Never commit to version control
BLINK_API_KEY=your_blink_api_key_here

# Blink Account ID
# Found in Blink dashboard under Account settings
# Format: typically a UUID or numeric ID
BLINK_ACCOUNT_ID=your_blink_account_id_here

# Optional: Blink Wallet ID (if using specific wallet)
# Defaults to primary wallet if not specified
BLINK_WALLET_ID=

# Optional: Network (mainnet or testnet)
# Use testnet for testing with mock/test funds
# BLINK_NETWORK=mainnet
BLINK_NETWORK=mainnet

# ============================================
# PAYMENT CONFIGURATION
# ============================================

# Default currency for payments
PAYMENT_DEFAULT_CURRENCY=XAF

# Invoice expiry time (in seconds)
# Default: 3600 (1 hour)
PAYMENT_INVOICE_EXPIRY=3600

# Lightning payment timeout (in seconds)
# Default: 600 (10 minutes for customer to pay)
PAYMENT_LIGHTNING_TIMEOUT=600

# Minimum payment amounts (in satoshis for BTC, in units for fiat)
PAYMENT_MIN_BTC=1000       # 0.00001 BTC (dust amount)
PAYMENT_MIN_LIGHTNING=100  # 100 satoshis
PAYMENT_MIN_MOMO=100       # 100 XAF cents
PAYMENT_MIN_XAF=100        # 100 XAF cents

# Maximum payment amounts
PAYMENT_MAX_BTC=10         # 10 BTC
PAYMENT_MAX_LIGHTNING=1000000 # ~1 BTC worth of satoshis
PAYMENT_MAX_MOMO=10000000  # 100,000 XAF (high limit for business)
PAYMENT_MAX_XAF=10000000   # 100,000 XAF

# Enable/disable payment methods
PAYMENT_LIGHTNING_ENABLED=true
PAYMENT_BTC_ENABLED=true
PAYMENT_MOMO_ENABLED=true
PAYMENT_ORANGE_ENABLED=false
PAYMENT_BANK_ENABLED=false

# ============================================
# WEBHOOK CONFIGURATION (for payment notifications)
# ============================================

# Webhook secret for verifying Blink webhook signatures
PAYMENT_WEBHOOK_SECRET=your_webhook_secret_here

# Webhook endpoint on your server
# Blink will POST payment updates to this URL
PAYMENT_WEBHOOK_URL=https://your-domain.com/api/payments/webhooks/blink

# ============================================
# LOGGING
# ============================================

# Enable detailed payment logging (be careful with production!)
PAYMENT_LOG_LEVEL=info
PAYMENT_DEBUG_PAYIN=false
PAYMENT_DEBUG_PAYOUT=false
