/**
 * =====================================================
 * GENERATOR & DATASOURCE
 * =====================================================
 */

generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

/**
 * =====================================================
 * ENUMS
 * =====================================================
 */

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  PAYMENT
  INVOICE
}

enum QuoteAmountType {
  PAY      // User controls what they spend
  RECEIVE  // User controls what recipient gets
}

enum PaymentFlow {
  DIRECT
  QR
  REQUEST
}


enum PaymentMethod {
  BTC
  LIGHTNING
  MOMO
  ORANGE
  CARD
  BANK
}

enum PayoutMethod {
  MOMO
  ORANGE
  BANK
  CRYPTO
}

enum TransactionStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  CANCELLED
}

enum LedgerEntryType {
  CREDIT
  DEBIT
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}
enum ContactType {
  EMAIL
  PHONE
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum UserRole {
  USER
  ADMIN
}

enum MerchantStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum MerchantBusinessType {
  RETAIL
  EVENTS
  SERVICES
  OTHER
}

/**
 * =====================================================
 * USER MODULE (CORE IDENTITY)
 * =====================================================
 */

model User {
  id             String    @id @default(uuid())
  password       String?
  firstName      String
  lastName       String
  profilePicture String?
  isActive       Boolean   @default(true)
  role           UserRole  @default(USER)
  kycStatus      KycStatus @default(PENDING)
  googleId       String?   @unique
  refreshToken   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts        UserContact[]
  wallets         Wallet[]
  transactions    Transaction[]
  kyc             Kyc?
  paymentRequests PaymentRequest[]
  paymentPreference    UserPaymentPreference?
  paymentPhoneSettings UserPaymentPhoneSettings[]

  paymentIdentity   PaymentIdentity? // 👈 NEW
  recipientInvoices PaymentInvoice[] @relation("RecipientInvoices")
  createdInvoices   PaymentInvoice[] @relation("CreatedInvoices")
  auditLogs         AuditLog[]
  sessions          UserSession[]
  merchantProfile   MerchantProfile?

  @@index([googleId])
}

/**
 * =====================================================
 * CONTACT SYSTEM (EMAIL / PHONE)
 * =====================================================
 */

model UserContact {
  id         String      @id @default(uuid())
  userId     String
  type       ContactType
  value      String
  pendingValue String?
  isPrimary  Boolean     @default(false)
  isVerified Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@unique([value])
  @@index([userId])
}

/**
 * =====================================================
 * VERIFICATION (OTP SYSTEM)
 * =====================================================
 */

model OtpCode {
  id        String   @id @default(uuid())
  scope     String
  subjectId String
  channel   String
  destination String
  code      String
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([scope, subjectId])
  @@index([destination])
}

/**
 * =====================================================
 * KYC MODULE
 * =====================================================
 */

model Kyc {
  id     String    @id @default(uuid())
  userId String    @unique
  status KycStatus @default(PENDING)

  // Identity Info
  firstName   String?
  lastName    String?
  dateOfBirth DateTime?

  // Documents
  idType          String?
  idNumber        String?
  documentUrl     String?
  documentBackUrl String?
  selfieUrl       String?

  // Metadata
  submittedAt     DateTime  @default(now())
  reviewedAt      DateTime?
  reviewedBy      String?
  rejectionReason String?

  // Risk & Scoring
  riskScore Int? @default(0)

  // Device / Geo
  ipAddress String?
  userAgent String?
  metadata  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

/**
 * =====================================================
 * MERCHANT MODULE
 * =====================================================
 */

model MerchantProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  businessName String
  businessType MerchantBusinessType
  description  String?

  status          MerchantStatus @default(PENDING)
  rejectionReason String?
  reviewedById    String?
  reviewedAt      DateTime?

  // Business payment handle (the @tchoko-bizness storefront identity).
  paymentIdentity PaymentIdentity?
  // Payments received by this business (PaymentInvoice tagged with this profile).
  invoices        PaymentInvoice[] @relation("MerchantInvoices")
  // Reusable payment-collection links owned by this business.
  paymentLinks    MerchantPaymentLink[] @relation("MerchantPaymentLinks")
  // Cash-out (withdrawal) requests from the merchant wallet.
  cashouts        MerchantCashout[] @relation("MerchantCashouts")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

/**
 * =====================================================
 * Currency MODULE
 * =====================================================
 */
model Currency {
  id String @id @default(uuid())

  code String @unique // XAF, USD, BTC, ETH, USDT
  name String

  symbol String?

  decimals Int // 2 for fiat, 8 for BTC
  isCrypto Boolean @default(false)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  wallets Wallet[]

  transactions Transaction[]

  paymentInvoices PaymentInvoice[]

  paymentAttempts PaymentAttempt[]

  quotes Quote[] @relation("BaseCurrency")

  quotesAsTarget Quote[] @relation("TargetCurrency")

  paymentLinkBases MerchantPaymentLink[] @relation("PaymentLinkBaseCurrency")

  cashouts MerchantCashout[] @relation("CashoutCurrency")

  countries Country[]

  limit TransactionLimit?
}

// ── Per-currency transaction floor/ceiling enforced during quote creation ──────
model TransactionLimit {
  id           String   @id @default(uuid())
  currencyCode String   @unique
  minAmount    Decimal  @db.Decimal(18, 2)
  maxAmount    Decimal  @db.Decimal(18, 2)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  currency Currency @relation(fields: [currencyCode], references: [code])

  @@index([currencyCode])
}

model Country {
  id          String   @id @default(uuid())
  iso2        String   @unique
  name        String
  dialCode    String?
  currencyId  String
  currency    Currency @relation(fields: [currencyId], references: [id])
  isActive    Boolean  @default(true)

  providers   PaymentProvider[]
  userPaymentPhoneSettings UserPaymentPhoneSettings[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * Registry of all payment aggregators integrated with TchokoPay.
 * Adding a new aggregator (Stripe, Flutterwave, Paystack, …) starts here.
 * Every PaymentProvider record is owned by exactly one aggregator so queries
 * never cross aggregator boundaries.
 */
model PaymentAggregator {
  id        String   @id @default(uuid())
  /// Short lowercase identifier used in code — never changes once set.
  /// Examples: 'netwalletpay', 'zikopay', 'blink'
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)

  /// Routing priority — lower number = tried first.
  /// Netwalletpay = 1 (primary), ZikoPay = 2 (fallback), etc.
  priority  Int      @default(99)

  /// Optional base URL override (useful for sandbox vs production)
  baseUrl   String?

  providers PaymentProvider[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([priority])
}

/**
 * Generic payment method categories — shared vocabulary across all aggregators.
 * Not aggregator-specific; MOBILE_MONEY means the same thing for Netwalletpay
 * and Flutterwave even though the underlying providers differ.
 */
model PaymentMethodRef {
  id       String  @id @default(uuid())
  code     String  @unique
  name     String
  isActive Boolean @default(true)

  providers PaymentProvider[]
}

/**
 * A concrete provider offered by a specific aggregator in a specific country.
 * Examples: mtn_cm (Netwalletpay, CM), mpesa_ke (Netwalletpay, KE).
 * When Stripe is added, its card processors will live here with aggregatorId = stripe.
 */
model PaymentProvider {
  id           String            @id @default(uuid())
  providerCode String            @unique
  name         String
  /// Which aggregator owns this provider record.
  /// Nullable only during migration — all records should have a value in production.
  aggregatorId String?
  aggregator   PaymentAggregator? @relation(fields: [aggregatorId], references: [id])
  countryId    String
  country      Country           @relation(fields: [countryId], references: [id])
  methodId     String
  method       PaymentMethodRef  @relation(fields: [methodId], references: [id])
  requiresType Boolean           @default(false)
  isActive     Boolean           @default(true)
  userPaymentPhoneSettings UserPaymentPhoneSettings[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([aggregatorId])
  @@index([countryId])
}

/**
 * =====================================================
 * QUOTE MODULE
 * =====================================================
 */

model Quote {
  id String @id @default(uuid())

  baseCurrencyId String
  baseCurrency   Currency @relation("BaseCurrency", fields: [baseCurrencyId], references: [id])

  targetCurrencyId String
  targetCurrency   Currency @relation("TargetCurrency", fields: [targetCurrencyId], references: [id])


  baseAmount   Decimal
  targetAmount Decimal

  exchangeRate Decimal?
  fee         Decimal?
  rateSource  String?
  
  amountType QuoteAmountType
  
  paymentMethod PaymentMethod
  payoutMethod  PayoutMethod
  
  flow PaymentFlow
  
  expiresAt DateTime
  isUsed    Boolean @default(false)

  createdAt DateTime @default(now())

  
  transactions Transaction[]
  invoices     PaymentInvoice[]

  @@index([baseCurrencyId])
  @@index([targetCurrencyId])
  @@index([amountType])
}

/**
 * =====================================================
 * FEE CONFIGURATION (DYNAMIC PRICING)
 * =====================================================
 */
model FeeConfig {
  id String @id @default(uuid())

  // 🎯 MATCHING CONDITIONS
  baseCurrencyCode   String? // BTC
  targetCurrencyCode String? // XAF
  paymentMethod      String? // payer side (BTC, MOMO, CARD)
  flow               String? // INVOICE, PAYOUT, QR
  payoutMethod String? // receiver side (MOMO, ORANGE)

  // 💰 PRICING
  feePercent    Decimal @default(0)
  spreadPercent Decimal @default(0)

  // 🔒 CONTROL
  isActive Boolean @default(true)
  priority Int     @default(0) // higher = more specific

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([baseCurrencyCode])
  @@index([targetCurrencyCode])
  @@index([paymentMethod])
  @@index([flow])
}

/**
 * =====================================================
 * WALLET MODULE
 * =====================================================
 */

model Wallet {
  id     String @id @default(uuid())
  userId String

  currencyId      String
  currency        Currency @relation(fields: [currencyId], references: [id])
  totalProcessed  Decimal  @default(0)
  totalVolume     Decimal  @default(0)
  totalFeesEarned Decimal  @default(0)
  // Spendable balance: held funds (e.g. payment-link collections) awaiting
  // cash-out. Credited on held collection, debited on approved withdrawal.
  availableBalance Decimal @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  transactions Transaction[]
  ledgers      Ledger[]

  @@unique([userId, currencyId])
  @@index([userId])
  @@index([currencyId])
}

/**
 * =====================================================
 * TRANSACTION MODULE
 * =====================================================
 */

model Transaction {
  id String @id @default(uuid())

  type   TransactionType
  status TransactionStatus @default(PENDING)

  quoteId String?
  quote   Quote?  @relation(fields: [quoteId], references: [id])

  amount     Decimal
  currencyId String
  currency   Currency @relation(fields: [currencyId], references: [id])

  exchangeRate Decimal?
  fee          Decimal?
  netAmount    Decimal?

  baseCurrencyId   String?
  targetCurrencyId String?

  baseAmount   Decimal?
  targetAmount Decimal?

  rateSource    String?
  rateTimestamp DateTime?

  paymentStatus String?
  payoutStatus  String?

  reference      String  @unique
  externalRef    String?
  provider       String?
  idempotencyKey String? @unique

  senderId   String?
  receiverId String?

  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  ipAddress      String?
  userAgent      String?
  channel        String?
  providerStatus String?
  metadata       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refunds       Refund[]
  disputes      Dispute[]
  ledgerEntries Ledger[]

  @@index([walletId])
  @@index([status])
  @@index([reference])
  @@index([externalRef])
  @@index([userId])
}

/**
 * =====================================================
 * PAYMENT MODULE
 * =====================================================
 */

model PaymentRequest {
  id     String @id @default(uuid())
  userId String

  amount   Decimal
  currency String
  status   TransactionStatus @default(PENDING)

  paymentLink String?
  expiresAt   DateTime?
  metadata    Json?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

/**
 * =====================================================
 * PAYMENT IDENTITY (PUBLIC HANDLE)
 * =====================================================
 */
enum PaymentIdentityKind {
  PERSONAL
  MERCHANT
}

model PaymentIdentity {
  id String @id @default(uuid())

  // PERSONAL identities carry the owning userId (nullable-unique keeps the
  // existing 1:1 User.paymentIdentity relation intact). MERCHANT identities
  // leave this null and link via merchantProfileId; their owner is derived
  // through merchantProfile.userId.
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // PERSONAL belongs to the user; MERCHANT represents a business (operated by
  // the owning user, but branded as the business).
  kind PaymentIdentityKind @default(PERSONAL)

  // Set only on MERCHANT identities — links the handle to the business profile.
  merchantProfileId String?          @unique
  merchantProfile   MerchantProfile? @relation(fields: [merchantProfileId], references: [id], onDelete: Cascade)

  // Which payout number receives money for this handle. Null on PERSONAL
  // identities (they fall back to the user's primary verified payout); set on
  // MERCHANT identities to the chosen business payout (inherited or dedicated).
  payoutSettingId String?
  payoutSetting   UserPaymentPhoneSettings? @relation(fields: [payoutSettingId], references: [id], onDelete: SetNull)

  handle String @unique // @tchoko-brian, @tchoko-bizness

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([handle])
}

model UserPaymentPreference {
  id String @id @default(uuid())

  userId String @unique
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  defaultPaymentMethod String @default("MOMO")
  defaultPayoutMethod String @default("MOMO")
  autoRefund Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserPaymentPhoneSettings {
  id String @id @default(uuid())

  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  paymentMethod String
  phone String @unique

  countryId String
  country Country @relation(fields: [countryId], references: [id])

  providerId String
  provider PaymentProvider @relation(fields: [providerId], references: [id])

  isPrimary Boolean @default(false)
  isVerified Boolean @default(false)
  isUserConfirmed Boolean @default(true)
  verifiedAt DateTime?

  // Merchant identities that route their business payout to this number.
  merchantIdentities PaymentIdentity[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([countryId])
  @@index([providerId])
}

/**
 * =====================================================
 * PAYMENT INVOICE (CORE ENGINE)
 * =====================================================
 */
model PaymentInvoice {
  id String @id @default(uuid())

  reference String @unique

  amount     Decimal
  currencyId String
  currency   Currency @relation(fields: [currencyId], references: [id])

  quoteId String?
  quote   Quote?  @relation(fields: [quoteId], references: [id])

  description String

  country String

  paymentMethod PaymentMethod? // how payer will pay (null for REQUEST CREATE until paid)
  flow          PaymentFlow? // DIRECT, QR, REQUEST

  // Who receives payment (USER ONLY or external phone)
  recipientId String?
  recipient   User?   @relation("RecipientInvoices", fields: [recipientId], references: [id])

  // Set when the payment was made to a business handle/storefront. Classifies
  // this as business money (separate analytics/statements from personal).
  merchantProfileId String?
  merchantProfile   MerchantProfile? @relation("MerchantInvoices", fields: [merchantProfileId], references: [id])

  // Set when the payment came through a merchant payment-collection link.
  paymentLinkId       String?
  merchantPaymentLink MerchantPaymentLink? @relation("PaymentLinkInvoices", fields: [paymentLinkId], references: [id])
  // Optional payer identity captured on the public link checkout.
  payerName  String?
  payerEmail String?

  recipientPhone String?
  recipientName  String?

  payoutMethod String // MOMO, ORANGE, etc.
  payoutProviderCode String?

  status TransactionStatus @default(PENDING)

  expiresAt DateTime

  createdById String? // optional (payer)
  createdBy   User?   @relation("CreatedInvoices", fields: [createdById], references: [id])

  paymentLink PaymentLink?

  attempts PaymentAttempt[]
  payout   Payout?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ledgerEntries Ledger[]

  @@index([recipientId])
  @@index([merchantProfileId])
  @@index([paymentLinkId])
  @@index([status])
  @@index([reference])
  @@index([currencyId])
}

/**
 * =====================================================
 * PAYMENT ATTEMPT (MULTI-PROVIDER FLOW)
 * =====================================================
 */
model PaymentAttempt {
  id String @id @default(uuid())

  invoiceId String
  invoice   PaymentInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  method PaymentMethod

  flow PaymentFlow? // DIRECT, QR, REQUEST

  status TransactionStatus @default(PENDING)

  fee Decimal?

  netAmount Decimal?

  provider String

  externalRef String?

  amount     Decimal
  currencyId String
  currency   Currency @relation(fields: [currencyId], references: [id])

  idempotencyKey String?

  failureReason    String?
  providerResponse Json?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@index([status])
}

/**
 * =====================================================
 * WEBHOOK EVENTS (IDEMPOTENCY)
 * =====================================================
 */
model WebhookEvent {
  id String @id @default(uuid())

  provider String

  eventId String @unique

  type String

  payload Json

  processed Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([eventId])
}

/**
 * =====================================================
 * IDEMPOTENCY (CRITICAL FINTECH FEATURE)
 * =====================================================
 */
model IdempotencyKey {
  id String @id @default(uuid())

  key String

  userId   String?
  endpoint String

  request  Json
  response Json?

  createdAt DateTime @default(now())

  @@unique([key, endpoint])
  @@index([userId])
}

/**
 * =====================================================
 * PAYOUT SYSTEM (ASYNC + RETRY)
 * =====================================================
 */
model Payout {
  id String @id @default(uuid())

  invoiceId String         @unique
  invoice   PaymentInvoice @relation(fields: [invoiceId], references: [id])

  amount   Decimal // net amount actually sent to the recipient (after any withdrawal fee)
  currency String

  // Withdrawal fee withheld from a merchant auto-payout (0 for normal payouts).
  fee Decimal @default(0)

  method PayoutMethod

  status TransactionStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attempts PayoutAttempt[]
}

/**
 * =====================================================
 * PAYOUT ATTEMPTS (RETRY ENGINE)
 * =====================================================
 */
model PayoutAttempt {
  id String @id @default(uuid())

  payoutId String
  payout   Payout @relation(fields: [payoutId], references: [id], onDelete: Cascade)

  status TransactionStatus @default(PENDING)

  provider String

  externalRef String?

  createdAt DateTime @default(now())

  @@index([payoutId])
}

/**
 * =====================================================
 * REFUND SYSTEM
 * =====================================================
 */
model Refund {
  id String @id @default(uuid())

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  amount Decimal

  reason String?

  status TransactionStatus @default(PENDING)

  provider String?

  externalRef String?

  createdAt DateTime @default(now())

  @@index([transactionId])
}

/**
 * =====================================================
 * DISPUTES
 * =====================================================
 */
model Dispute {
  id String @id @default(uuid())

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  reason String

  status DisputeStatus @default(OPEN)

  resolution String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([transactionId])
}

/**
 * =====================================================
 * AUDIT LOG (COMPLIANCE)
 * =====================================================
 */
model AuditLog {
  id String @id @default(uuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  action    String
  entity    String
  entityId  String?
  ipAddress String?
  userAgent String?
  metadata  Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

/**
 * =====================================================
 * USER SESSIONS (SESSION MANAGEMENT)
 * Lets users see and revoke active sessions.
 * =====================================================
 */
model UserSession {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceName String?
  ipAddress  String?
  userAgent  String?
  deviceHash String?
  isRevoked  Boolean  @default(false)

  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())
  revokedAt    DateTime?

  @@index([userId])
  @@index([deviceHash])
}

/**
 * =====================================================
 * ADMIN AUDIT LOG — records every admin action
 * Required for fintech compliance and incident response.
 * =====================================================
 */
model AdminAuditLog {
  id         String  @id @default(uuid())
  adminId    String
  /// Human-readable action code e.g. USER_BANNED, KYC_APPROVED, ROLE_CHANGED
  action     String
  /// Which domain this action targets: USER | INVOICE | KYC | PRICING | SYSTEM
  targetType String
  targetId   String?
  /// Extra context: old value, new value, reason, etc.
  metadata   Json?
  ipAddress  String?

  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
}

/**
 * =====================================================
 * PAYMENT LINK (FOR SHARING)
 * =====================================================
 */
model PaymentLink {
  id String @id @default(uuid())

  invoiceId String         @unique
  invoice   PaymentInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  url String @unique

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  expiresAt DateTime?

  @@index([url])
}

enum PaymentLinkKind {
  LINK
  EVENT
}

/// A merchant's reusable payment-collection link: one link, many payers.
/// Payers each pay the equivalent of `baseAmount` in `baseCurrency`; every
/// payment becomes a PaymentInvoice tagged with this link. With kind=EVENT it
/// also carries event identity (title, type, branding) for a registration page.
model MerchantPaymentLink {
  id String @id @default(uuid())

  merchantProfileId String
  merchantProfile   MerchantProfile @relation("MerchantPaymentLinks", fields: [merchantProfileId], references: [id], onDelete: Cascade)

  slug String @unique // short unguessable token used in the public URL

  kind PaymentLinkKind @default(LINK)

  reason      String // LINK: headline ("Rent Collection"). EVENT: what to collect ("Registration").
  description String?

  // EVENT-only identity/branding
  eventType     String? // CONFERENCE, SEMINAR, WORKSHOP, ...
  title         String? // "Bitcoin Kids 2025"
  coverImageUrl String?
  logoUrl       String?

  baseCurrencyId String
  baseCurrency   Currency @relation("PaymentLinkBaseCurrency", fields: [baseCurrencyId], references: [id])
  baseAmount     Decimal // fixed amount in the base currency

  // When false (default) payments are held to the merchant wallet for later
  // admin-approved cash-out; when true they auto-route to the payout number.
  autoRoutePayout Boolean @default(false)

  isActive  Boolean   @default(true)
  expiresAt DateTime?

  invoices PaymentInvoice[] @relation("PaymentLinkInvoices")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([merchantProfileId])
  @@index([slug])
}

/// Single-row platform configuration (id is always "singleton").
model PlatformConfig {
  id String @id @default("singleton")

  // When false (default) ALL merchant money is held to the merchant wallet for
  // admin-approved cash-out; when true merchant payments auto-route on receipt.
  merchantAutoRoutePayout Boolean @default(false)

  // Minimum amount a merchant can request to withdraw (settlement currency).
  minWithdrawalAmount Int @default(500)

  updatedAt DateTime @updatedAt
}

enum CashoutStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
  FAILED
}

/// A merchant's request to withdraw held wallet funds to their payout number.
model MerchantCashout {
  id String @id @default(uuid())

  reference String @unique

  merchantProfileId String
  merchantProfile   MerchantProfile @relation("MerchantCashouts", fields: [merchantProfileId], references: [id], onDelete: Cascade)
  userId            String

  amount    Decimal // gross requested (debited from wallet)
  fee       Decimal @default(0) // withdrawal fee (platform revenue)
  netAmount Decimal // amount - fee, what is actually paid out

  currencyId String
  currency   Currency @relation("CashoutCurrency", fields: [currencyId], references: [id])

  // Snapshot of the payout destination at request time.
  payoutPhone        String?
  payoutMethod       String?
  payoutProviderCode String?
  country            String?

  status CashoutStatus @default(PENDING)

  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  externalRef     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([merchantProfileId])
  @@index([status])
}

/**
 * =====================================================
 * lEDGER (FINANCIAL RECORDS)
 * =====================================================
 */
model Ledger {
  id String @id @default(uuid())

  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id])

  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  invoiceId String?
  invoice   PaymentInvoice? @relation(fields: [invoiceId], references: [id])

  amount Decimal

  type LedgerEntryType // CREDIT | DEBIT

  balanceAfter Decimal

  createdAt DateTime @default(now())

  @@index([walletId])
  @@index([transactionId])
  @@index([invoiceId])
}
